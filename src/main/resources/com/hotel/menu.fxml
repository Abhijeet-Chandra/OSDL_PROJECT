<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.controller.MenuController">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/>
    </padding>
    <top>
        <VBox spacing="12.0">
            <Label styleClass="page-title" text="Rooms management"/>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Button onAction="#onRefresh" text="Refresh"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="table" prefHeight="400.0">
            <columns>
                <TableColumn fx:id="colRoomNumber" prefWidth="90.0" text="Room #"/>
                <TableColumn fx:id="colRoomType" prefWidth="180.0" text="Type"/>
                <TableColumn fx:id="colCapacity" prefWidth="110.0" text="Capacity"/>
                <TableColumn fx:id="colDailyRate" prefWidth="140.0" text="Daily rate"/>
                <TableColumn fx:id="colStatus" prefWidth="110.0" text="Status"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <VBox spacing="12.0">
            <Separator/>
            <Label styleClass="section-title" text="Add / edit room"/>
            <GridPane hgap="10.0" vgap="10.0">
                <Label text="Room number" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="roomNumberField" promptText="e.g. 101" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Room type" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="roomTypeField" promptText="e.g. Single / Double" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Capacity" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="capacityField" promptText="e.g. 2" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Daily rate (₹)" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="dailyRateField" promptText="e.g. 3500.00" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Status" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <ComboBox fx:id="statusCombo" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            </GridPane>
            <HBox spacing="10.0">
                <Button onAction="#onAdd" text="Add"/>
                <Button onAction="#onUpdate" text="Update selected"/>
                <Button onAction="#onDelete" text="Delete selected"/>
                <Button onAction="#onClearForm" text="Clear form"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>

