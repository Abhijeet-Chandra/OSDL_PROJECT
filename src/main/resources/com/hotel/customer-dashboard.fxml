<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hotel.controller.CustomerDashboardController" spacing="18.0">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
    </padding>
    <Label styleClass="page-title" text="My stay"/>
    <Label fx:id="welcomeLabel" styleClass="stat-value" text="Welcome"/>
    <Label fx:id="profileLabel" styleClass="muted" text="Profile"/>

    <VBox spacing="12.0" styleClass="hint-card">
        <Label styleClass="hint-title" text="At a glance"/>
        <HBox spacing="24.0">
            <VBox spacing="4.0" styleClass="stat-card" prefWidth="200.0">
                <Label styleClass="stat-label" text="Active / upcoming stays"/>
                <Label fx:id="activeStaysLabel" styleClass="stat-value" text="0"/>
            </VBox>
            <VBox spacing="6.0" HBox.hgrow="ALWAYS" styleClass="stat-card accent">
                <Label styleClass="stat-label" text="Next on your itinerary"/>
                <Label fx:id="nextStayLabel" styleClass="hint-body" text="—" wrapText="true"/>
            </VBox>
        </HBox>
    </VBox>

    <VBox spacing="8.0" styleClass="hint-card">
        <Label styleClass="hint-title" text="Quick actions"/>
        <HBox spacing="10.0">
            <Button mnemonicParsing="false" onAction="#onBookRoom" text="Book a room"/>
            <Button mnemonicParsing="false" onAction="#onMyBookings" text="My bookings"/>
            <Button mnemonicParsing="false" onAction="#onMyBills" text="My bills"/>
        </HBox>
    </VBox>
</VBox>
