<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.controller.MainController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="nav-bar">
            <padding>
                <Insets bottom="12.0" left="16.0" right="16.0" top="12.0"/>
            </padding>
            <Label styleClass="nav-title" text="Hotel Management"/>
            <HBox alignment="CENTER" spacing="8.0" HBox.hgrow="ALWAYS">
                <Button fx:id="btnDashboard" mnemonicParsing="false" onAction="#showDashboard" text="Dashboard"/>
                <Button fx:id="btnRooms" mnemonicParsing="false" onAction="#showMenu" text="Rooms"/>
                <Button fx:id="btnBookings" mnemonicParsing="false" onAction="#showBookings" text="Bookings"/>
                <Button fx:id="btnBilling" mnemonicParsing="false" onAction="#showBilling" text="Book room"/>
                <Button fx:id="btnExtras" mnemonicParsing="false" onAction="#showExtras" text="Extras"/>
                <Button fx:id="btnHistory" mnemonicParsing="false" onAction="#showHistory" text="Bill history"/>
            </HBox>
            <VBox spacing="4.0" alignment="CENTER_RIGHT">
                <Label fx:id="lblAccount" styleClass="muted" text=""/>
                <Button mnemonicParsing="false" onAction="#onLogout" text="Log out"/>
            </VBox>
        </HBox>
    </top>
    <center>
        <StackPane fx:id="contentPane" styleClass="content-root"/>
    </center>
</BorderPane>
