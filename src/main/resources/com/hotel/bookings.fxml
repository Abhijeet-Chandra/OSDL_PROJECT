<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.controller.BookingsController">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/>
    </padding>
    <top>
        <VBox spacing="8.0">
            <Label fx:id="pageTitleLabel" styleClass="page-title" text="Bookings"/>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Label text="Filter status"/>
                <ComboBox fx:id="statusFilter" prefWidth="200.0"/>
                <Button fx:id="refreshButton" mnemonicParsing="false" onAction="#onRefresh" text="Refresh"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="bookingTable" prefHeight="450.0" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colBookingId" prefWidth="80.0" text="ID"/>
                <TableColumn fx:id="colGuest" prefWidth="220.0" text="Guest"/>
                <TableColumn fx:id="colRoom" prefWidth="110.0" text="Room"/>
                <TableColumn fx:id="colCheckIn" prefWidth="140.0" text="Check-in"/>
                <TableColumn fx:id="colCheckOut" prefWidth="140.0" text="Check-out"/>
                <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <HBox spacing="12.0">
            <Button fx:id="checkOutButton" mnemonicParsing="false" onAction="#onCheckOut" text="Check-out"/>
            <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#onCancelBooking" text="Cancel booking"/>
        </HBox>
    </bottom>
</BorderPane>

