<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hotel.controller.HistoryController" spacing="12.0">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/>
    </padding>
    <Label fx:id="pageTitleLabel" styleClass="page-title" text="Bill history"/>
    <HBox alignment="CENTER_LEFT" spacing="12.0">
        <Label text="Date"/>
        <DatePicker fx:id="datePicker"/>
        <Button mnemonicParsing="false" onAction="#onRefresh" text="Refresh"/>
        <Button mnemonicParsing="false" onAction="#onShowDetails" text="Show details"/>
    </HBox>
    <TableView fx:id="billTable" prefHeight="420.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colBillId" prefWidth="70.0" text="Bill #"/>
            <TableColumn fx:id="colTime" prefWidth="160.0" text="Time"/>
            <TableColumn fx:id="colStudent" prefWidth="120.0" text="Guest"/>
            <TableColumn fx:id="colSub" prefWidth="100.0" text="Subtotal"/>
            <TableColumn fx:id="colTax" prefWidth="90.0" text="Tax"/>
            <TableColumn fx:id="colTot" prefWidth="110.0" text="Total"/>
        </columns>
    </TableView>
</VBox>

